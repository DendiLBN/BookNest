{
  "name": "bookstore",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "frontend": "npm run dev --prefix ./frontend",
    "backend": "npm run start:dev --prefix ./backend",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "format": "biome check --write . && npm run lint:fix --prefix ./frontend -- .",
    "format:staged": "lint-staged",
    "format:check": "biome check . && npm run lint --prefix ./frontend",
    "prepare": "husky",
    "test": "npm run test --prefix ./frontend && npm run test --prefix ./backend",
    "build": "npm run build --prefix ./frontend && npm run build --prefix ./backend"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "concurrently": "^8.2.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0"
  },
  "dependencies": {
    "@nestjs/jwt": "^10.2.0"
  },
  "lint-staged": {
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "biome check --write --no-errors-on-unmatched",
      "npm run lint:fix --prefix ./frontend --"
    ],
    "*.{json,jsonc,css,md,cjs,mjs}": "biome check --write --no-errors-on-unmatched",
    "backend/**/*.{ts,js,jsx}": "biome check --write --no-errors-on-unmatched"
  }
}
